# Mom Slack Bot — copy to .env.mom and fill in values
# .env.mom is gitignored via the **/.env* pattern
#
# Create Slack app using slack-app-manifest.json, then:
# 1. Socket Mode > Generate App-Level Token (connections:write scope)
# 2. Install App > Copy Bot User OAuth Token

# App-Level Token (Socket Mode) — starts with xapp-
MOM_SLACK_APP_TOKEN=xapp-1-...
# Bot User OAuth Token — starts with xoxb-
MOM_SLACK_BOT_TOKEN=xoxb-...

# Model config (optional, these are the defaults)
# MOM_PROVIDER=openai-codex
# MOM_MODEL=gpt-5.4
